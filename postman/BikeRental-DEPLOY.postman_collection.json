				{
					"name": "Crear bicicleta",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 201 Created\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"pm.test(\"Tiene c??digo\", function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.code).to.eql(\"BIC-100\");",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"code\": \"BIC-100\",\n  \"type\": \"URBANA\",\n  \"status\": \"DISPONIBLE\"\n}"
						},
						"url": {
							"raw": "http://13.220.253.30:8080/api/bicycles",
							"protocol": "http",
							"host": ["13.220.253.30"],
							"port": "8080",
							"path": ["api", "bicycles"]
						}
					}
				},
