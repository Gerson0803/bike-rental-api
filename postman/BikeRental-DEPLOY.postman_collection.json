					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 201 Created\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"pm.test(\"Tiene ID\", function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property(\"id\");",
									"});",
									"",
									"pm.collectionVariables.set(\"rentalId\", pm.response.json().id);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"bicycleCode\": \"BIC-001\",\n  \"customerName\": \"Juan P??rez\",\n  \"estimatedHours\": 2,\n  \"startTime\": \"2026-06-14T10:00:00\"\n}"
						},
						"url": {
							"raw": "http://13.220.253.30:8080/api/rentals",
							"protocol": "http",
